NEXT_PUBLIC_SITE_URL=https://severinosantalucia.dev

# Email provider (Resend / Postmark / SMTP). Used by actions/contact.actions.ts.
# CONTACT_FROM_EMAIL=info@severinosantalucia.dev
# RESEND_API_KEY=re_xxx

# GitHub API (opzionale).
# Senza token: 60 richieste/ora (unauth) — sufficiente con ISR 1h.
# Con token: 5000 richieste/ora. Crea un classic token con scope "public_repo" su
# https://github.com/settings/tokens e incollalo qui.
# GITHUB_TOKEN=ghp_xxx
